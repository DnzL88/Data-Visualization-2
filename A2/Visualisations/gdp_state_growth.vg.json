{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "GDP Growth by Malaysian State (% from 2023)",
  "width": 500,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/DnzL88/Data-Visualization-2/refs/heads/main/A2/Dataset_files/GDP_by_state.csv"
  },
  "transform": [
    {
      "joinaggregate": [
        {
          "op": "mean",
          "field": "Growth_from_2023",
          "as": "AverageGrowth"
        }
      ]
    },
    {
      "calculate": "datum.Growth_from_2023 >= datum.AverageGrowth ? 'Above Average' : 'Below Average'",
      "as": "GrowthCategory"
    },
    {
      "calculate": "'Average growth: ' + format(datum.AverageGrowth, '.2f') + '%'",
      "as": "AverageLabel"
    }
  ],
  "layer": [
    {
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "Growth_from_2023",
          "type": "quantitative",
          "title": "GDP Growth in 2024 (%)"
        },
        "y": {
          "field": "Country",
          "type": "ordinal",
          "sort": "-x",
          "title": "State"
        },
        "color": {
          "field": "GrowthCategory",
          "type": "nominal",
          "scale": {
            "domain": ["Above Average", "Below Average"],
            "range": ["#1a3a5c", "#d3d3d3"]
          },
          "legend": {"title": "Growth"}
        },
        "tooltip": [
          {"field": "Country", "type": "nominal", "title": "State"},
          {"field": "Growth_from_2023", "type": "quantitative", "title": "Growth in 2024 (%)", "format": ".1f"},
          {"field": "GrowthCategory", "type": "nominal", "title": "Category"}
        ]
      }
    },
    {
      "mark": {"type": "rule", "color": "red", "strokeWidth": 2, "strokeDash": [4, 4]},
      "encoding": {
        "x": {
          "field": "AverageGrowth",
          "type": "quantitative",
          "aggregate": "mean"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "color": "red",
        "align": "left",
        "dx": 5,
        "dy": 300,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "AverageGrowth",
          "type": "quantitative",
          "aggregate": "mean"
        },
        "y": {"value": 0},
        "text": {
          "field": "AverageLabel",
          "type": "nominal"
        }
      }
    }
  ]
}