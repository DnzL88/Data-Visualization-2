{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Manufacturing output breakdown donut chart",
  "width": 200,
  "height": 200,
  "data": {
    "url": "https://raw.githubusercontent.com/DnzL88/Data-Visualization-2/refs/heads/main/A2/Dataset_files/Manufacturing.csv"
  },
  "layer": [
    {
      "mark": {"type": "arc", "innerRadius": 60, "outerRadius": 100},
      "encoding": {
        "theta": {"field": "Share", "type": "quantitative"},
        "color": {
          "field": "Manufacturing",
          "type": "nominal",
          "legend": {"title": "Sector"}
        },
        "tooltip": [
          {"field": "Manufacturing", "type": "nominal", "title": "Sector"},
          {"field": "Share", "type": "quantitative", "title": "Share (%)"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "radius": 0,
        "fontSize": 9,
        "fontWeight": "bold",
        "lineBreak": "\n"
      },
      "encoding": {
        "text": {"value": ["Total manufacturing output:", "RM307,500.501 mil"]}
      }
    }
  ]
}