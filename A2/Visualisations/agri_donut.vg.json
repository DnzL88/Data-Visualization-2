{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Agriculture sector breakdown donut chart",
  "width": 200,
  "height": 200,
  "data": {
    "url": "https://raw.githubusercontent.com/DnzL88/Data-Visualization-2/refs/heads/main/A2/Dataset_files/Agriculture.csv"
  },
  "layer": [
    {
      "mark": {"type": "arc", "innerRadius": 60, "outerRadius": 100},
      "encoding": {
        "theta": {"field": "Share", "type": "quantitative"},
        "color": {
          "field": "Agriculture",
          "type": "nominal",
          "legend": {"title": "Agriculture Subsector"},
          "scale": {
            "domain": ["Fishing", 
                        "Forestry & Logging", 
                        "Livestock", 
                        "Other Agriculture", 
                        "Palm oil", 
                        "Rubber"],
            "range": [
                      "#1F78B4", "#8C6D31", 
                      "#E69F00", "#BDBDBD", 
                      "#6A3D9A", "#FDD835"]
          }
        },
        "tooltip": [
          {"field": "Agriculture", "type": "nominal", "title": "Subsector"},
          {"field": "Share", "type": "quantitative", "title": "Share (%)"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 9,
        "fontWeight": "bold",
        "lineBreak": "\n"
      },
      "encoding": {
        "text": {"value": ["Total Agriculture Output:", "RM83,863.77 mil"]}
      }
    }
  ]
}

