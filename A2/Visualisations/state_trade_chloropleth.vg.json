{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Malaysia Net Export Balance by State",
    "subtitle": "Blue = More exports than imports | Red = More imports than exports",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "anchor": "middle",
    "offset": 10
  },
  "width": 800,
  "height": 300,
  "projection": {
    "type": "mercator",
    "center": [108.5, 4],
    "scale": 2000
  },
  "data": {
    "url": "https://raw.githubusercontent.com/DnzL88/Data-Visualization-2/refs/heads/main/A2/malaysia_states.topojson",
    "format": {
      "type": "topojson",
      "feature": "gadm41_MYS_1"
    }
  },
  "transform": [
    {
      "lookup": "properties.NAME_1",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/DnzL88/Data-Visualization-2/refs/heads/main/A2/Dataset_files/Trade_by_states.csv"
        },
        "key": "State",
        "fields": ["Export", "Import"]
      }
    },
    {
      "calculate": "((datum.Export - datum.Import) / datum.Import) * 100",
      "as": "Net Export %"
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "black",
    "strokeWidth": 0.8
  },
  "encoding": {
    "color": {
      "field": "Net Export %",
      "type": "quantitative",
      "scale": {
        "scheme": "redblue",
        "domainMid": 0
      },
      "legend": {
        "title": "Net Export Balance (%)",
        "format": "+.1f",
        "gradientLength": 150,
        "orient": "none",
        "legendX": 300,
        "legendY": 10,
        "direction": "horizontal"
    }
    },
    "tooltip": [
      {
        "field": "properties.NAME_1",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "Export",
        "type": "quantitative",
        "title": "Exports (US$ billion)",
        "format": ",.2f"
      },
      {
        "field": "Import",
        "type": "quantitative",
        "title": "Imports (US$ billion)",
        "format": ",.2f"
      },
      {
        "field": "Net Export %",
        "type": "quantitative",
        "title": "Net Export Balance",
        "format": "+.1f"
      }
    ]
  }
}