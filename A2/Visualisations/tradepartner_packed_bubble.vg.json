{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "Malaysia Export Trade Partners – Packed Bubble Chart (largest values centred)",
  "width": 100,
  "height": 200,
  "padding": 1,
  "data": [
    {
      "name": "positions",
      "values": [
        {
          "name": "Singapore",
          "x_target": -45,
          "y_target": -105,
          "fixed": true
        },
        {
          "name": "United States",
          "x_target": 45,
          "y_target": -90,
          "fixed": true
        },
        {
          "name": "mainland China",
          "x_target": -60,
          "y_target": -20,
          "fixed": true
        },
        {
          "name": "Other",
          "x_target": -140,
          "y_target": 145,
          "fixed": true
        },
        {
          "name": "Hong Kong",
          "x_target": 16,
          "y_target": -4,
          "fixed": true
        },
        {
          "name": "Taiwan",
          "x_target": -50,
          "y_target": 55,
          "fixed": true
        },
        {
          "name": "Japan",
          "x_target": -120,
          "y_target": -72,
          "fixed": true
        },
        {
          "name": "Thailand",
          "x_target": -138,
          "y_target": -5,
          "fixed": true
        },
        {
          "name": "Vietnam",
          "x_target": -131,
          "y_target": 60,
          "fixed": true
        },
        {
          "name": "South Korea",
          "x_target": -110,
          "y_target": 120,
          "fixed": true
        },
        {
          "name": "India",
          "x_target": 25,
          "y_target": 70,
          "fixed": true
        },
        {
          "name": "Indonesia",
          "x_target": -70,
          "y_target": 165,
          "fixed": true
        },
        {
          "name": "Australia",
          "x_target": 85,
          "y_target": -18,
          "fixed": true
        },
        {
          "name": "Netherlands",
          "x_target": 140,
          "y_target": 20,
          "fixed": true
        },
        {
          "name": "Germany",
          "x_target": 75,
          "y_target": 40,
          "fixed": true
        },
        {
          "name": "Mexico",
          "x_target": 113,
          "y_target": -70,
          "fixed": true
        },
        {
          "name": "Philippines",
          "x_target": -35,
          "y_target": 115,
          "fixed": true
        },
        {
          "name": "Turkiye",
          "x_target": -10,
          "y_target": 180,
          "fixed": true
        },
        {
          "name": "United Arab Emirates",
          "x_target": 30,
          "y_target": 130,
          "fixed": true
        },
        {
          "name": "Bangladesh",
          "x_target": 45,
          "y_target": 175,
          "fixed": true
        },
        {
          "name": "United Kingdom",
          "x_target": 140,
          "y_target": 75,
          "fixed": true
        },
        {
          "name": "Italy",
          "x_target": 100,
          "y_target": 85,
          "fixed": true
        },
        {
          "name": "Belgium",
          "x_target": 115,
          "y_target": 125,
          "fixed": true
        },
        {
          "name": "Canada",
          "x_target": 140,
          "y_target": -30,
          "fixed": true
        },
        {
          "name": "France",
          "x_target": 75,
          "y_target": 120,
          "fixed": true
        },
        {
          "name": "Kenya",
          "x_target": 90,
          "y_target": 160,
          "fixed": true
        }
      ]
    },
    {
      "name": "table",
      "url": "https://raw.githubusercontent.com/DnzL88/Data-Visualization-2/refs/heads/main/A2/Dataset_files/Trade_partners.csv",
      "format": {
        "type": "csv"
      },
      "transform": [
        {
          "type": "formula",
          "as": "export_num",
          "expr": "toNumber(datum['Export(US$billion)'])"
        },
        {
          "type": "formula",
          "as": "r",
          "expr": "sqrt(datum.export_num / 58.3) * 85"
        },
        {
          "type": "lookup",
          "from": "positions",
          "key": "name",
          "fields": [
            "Trade_partner"
          ],
          "values": [
            "x_target",
            "y_target",
            "fixed"
          ]
        },
        {
          "type": "formula",
          "as": "fx",
          "expr": "datum.fixed ? datum.x_target : null"
        },
        {
          "type": "formula",
          "as": "fy",
          "expr": "datum.fixed ? datum.y_target : null"
        },
        {
          "type": "force",
          "static": true,
          "iterations": 600,
          "forces": [
            {
              "force": "x",
              "x": {
                "field": "x_target"
              },
              "strength": 0.35
            },
            {
              "force": "y",
              "y": {
                "field": "y_target"
              },
              "strength": 0.35
            },
            {
              "force": "collide",
              "radius": {
                "field": "r"
              },
              "strength": 1,
              "iterations": 6
            },
            {
              "force": "nbody",
              "strength": -8
            }
          ]
        },
        {
          "type": "formula",
          "as": "x",
          "expr": "datum.fixed ? datum.x_target : datum.x"
        },
        {
          "type": "formula",
          "as": "y",
          "expr": "datum.fixed ? datum.y_target : datum.y"
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "size",
      "type": "sqrt",
      "domain": {
        "data": "table",
        "field": "export_num"
      },
      "range": [
        80,
        7225
      ]
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": [
        "Asia",
        "North America",
        "Europe",
        "Oceania",
        "Africa",
        "Other"
      ],
      "range": [
        "#E15759",
        "#59A14F",
        "#4E79A7",
        "#76B7B2",
        "#F4C0D1",
        "#D3D1C7"
      ]
    },
    {
      "name": "stroke",
      "type": "ordinal",
      "domain": [
        "Asia",
        "North America",
        "Europe",
        "Oceania",
        "Africa",
        "Other"
      ],
      "range": [
        "#9C2F35",
        "#356B30",
        "#2F4F6F",
        "#3F4A67",
        "#993556",
        "#5F5E5A"
      ]
    },
    {
      "name": "textColor",
      "type": "ordinal",
      "domain": [
        "Asia",
        "North America",
        "Europe",
        "Oceania",
        "Africa",
        "Other"
      ],
      "range": [
        "#1F1F1F",
        "#FFFFFF",
        "#FFFFFF",
        "#1F1F1F",
        "#FFFFFF",
        "#FFFFFF"
      ]
    }
  ],
  "legends": [
    {
      "fill": "color",
      "stroke": "stroke",
      "title": "Region",
      "orient": "bottom",
      "direction": "horizontal",
      "symbolType": "circle",
      "symbolSize": 100,
      "labelColor": "#444",
      "titleColor": "#222",
      "columns": 3
    }
  ],
  "marks": [
    {
      "name": "bubbles",
      "type": "symbol",
      "from": {
        "data": "table"
      },
      "encode": {
        "enter": {
          "shape": {
            "value": "circle"
          },
          "fill": {
            "scale": "color",
            "field": "Region"
          },
          "stroke": {
            "scale": "stroke",
            "field": "Region"
          },
          "strokeWidth": {
            "value": 1.5
          },
          "size": {
            "scale": "size",
            "field": "export_num"
          },
          "tooltip": {
            "signal": "{\"Trade Partner\": datum.Trade_partner, \"Exports (US$B)\": format(datum.export_num, '.1f'), \"Region\": datum.Region}"
          }
        },
        "update": {
          "x": {
            "field": "x"
          },
          "y": {
            "field": "y"
          }
        }
      }
    },
    {
      "type": "text",
      "from": {
        "data": "table"
      },
      "encode": {
        "enter": {
          "align": {
            "value": "center"
          },
          "baseline": {
            "value": "middle"
          },
          "fontSize": {
            "signal": "max(9, min(13, datum.r * 0.35))"
          },
          "fontWeight": {
            "value": "500"
          },
          "fill": {
            "scale": "textColor",
            "field": "Region"
          },
          "text": {
            "signal": "datum.r > 18 ? datum.Trade_partner : ''"
          },
          "tooltip": {
            "signal": "{\"Trade Partner\": datum.Trade_partner, \"Exports (US$B)\": format(datum.export_num, '.1f'), \"Region\": datum.Region}"
          }
        },
        "update": {
          "x": {
            "field": "x"
          },
          "y": {
            "field": "y"
          }
        }
      }
    },
    {
      "type": "text",
      "from": {
        "data": "table"
      },
      "encode": {
        "enter": {
          "align": {
            "value": "center"
          },
          "baseline": {
            "value": "middle"
          },
          "dy": {
            "signal": "datum.r * 0.38"
          },
          "fontSize": {
            "signal": "max(8, min(11, datum.r * 0.26))"
          },
          "fontWeight": {
            "value": "400"
          },
          "opacity": {
            "value": 0.8
          },
          "fill": {
            "scale": "textColor",
            "field": "Region"
          },
          "text": {
            "signal": "datum.r > 30 ? format(datum.export_num, '.1f') + 'B' : ''"
          },
          "tooltip": {
            "signal": "{\"Trade Partner\": datum.Trade_partner, \"Exports (US$B)\": format(datum.export_num, '.1f'), \"Region\": datum.Region}"
          }
        },
        "update": {
          "x": {
            "field": "x"
          },
          "y": {
            "field": "y"
          }
        }
      }
    }
  ]
}