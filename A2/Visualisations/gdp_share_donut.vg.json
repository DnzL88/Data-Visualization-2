{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Malaysia GDP Share by Sector",
  "width": 400,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/DnzL88/Data-Visualization-2/refs/heads/main/A2/Dataset_files/GDP_share.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 100
      },
      "encoding": {
        "theta": {
          "field": "GDP share",
          "type": "quantitative"
        },
        "color": {
          "field": "Sector",
          "type": "nominal",
          "scale": {
            "domain": [
              "Services",
              "Manufacturing",
              "Agriculture",
              "Mining & Quarrying",
              "Construction",
              "others"
            ],
            "range": [
              "#1D9E75",
              "#378ADD",
              "#EF9F27",
              "#D4537E",
              "#7F77DD",
              "#888780"
            ]
          },
          "legend": {
            "title": "Sector"
          }
        },
        "tooltip": [
          {
            "field": "Sector",
            "type": "nominal",
            "title": "Sector"
          },
          {
            "field": "GDP share",
            "type": "quantitative",
            "title": "GDP Share (%)"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 13,
        "fontWeight": "bold",
        "lineBreak": "\n"
      },
      "encoding": {
        "text": {
          "value": "Total GDP 2024:\nRM1,331,171 mil"
        }
      }
    }
  ]
}