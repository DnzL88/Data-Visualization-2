{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Malaysia GDP by State (MYR millions)",
  "width": 550,
  "height": 250,
  "projection": {
    "type": "equalEarth",
    "center": [108.5, 4],
    "scale": 1700
  },
  "data": {
    "url": "https://raw.githubusercontent.com/DnzL88/Data-Visualization-2/refs/heads/main/A2/malaysia_states.topojson",
    "format": {
      "type": "topojson",
      "feature": "gadm41_MYS_1"
    }
  },
  "transform": [
    {
      "lookup": "properties.NAME_1",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/DnzL88/Data-Visualization-2/refs/heads/main/A2/Dataset_files/GDP_by_state.csv"
        },
        "key": "Country",
        "fields": [
          "precentage"
        ]
      }
    }
    
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "black",
    "strokeWidth": 0.8
  },
  "encoding": {
    "color": {
      "field": "precentage",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "legend": {
        "title": "Percentage of GDP (%)",
        "format": ",.0f",
        "orient": "top",
        "direction": "horizontal"
      }
    },
    "tooltip": [
      {
        "field": "properties.NAME_1",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "precentage",
        "type": "quantitative",
        "title": "Percentage of GDP",
        "format": ",.0f"
      }
    ]
  }
}  