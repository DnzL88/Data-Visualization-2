{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Malaysia GDP by State (MYR millions)",
  "width": 800,
  "height": 450,
  "projection": {
    "type": "equalEarth"
  },
  "data": {
    "url": "A2/malaysia_states.topojson",
    "format": {
      "type": "topojson",
      "feature": "gadm41_MYS_1"
    }
  },
  "transform": [
    {
      "lookup": "properties.NAME_1",
      "from": {
        "data": {
          "url": "A2/Dataset_files/GDP_by_state.csv"
        },
        "key": "Country",
        "fields": [
          "GDP(million)"
        ]
      }
    }
    
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "black",
    "strokeWidth": 0.8
  },
  "encoding": {
    "color": {
      "field": "GDP(million)",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "legend": {
        "title": "GDP (MYR millions)",
        "format": ",.0f"
      }
    },
    "tooltip": [
      {
        "field": "properties.NAME_1",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "GDP(million)",
        "type": "quantitative",
        "title": "GDP (MYR millions)",
        "format": ",.0f"
      }
    ]
  }
}