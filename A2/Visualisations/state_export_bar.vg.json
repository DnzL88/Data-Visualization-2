{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Malaysia Imports by State (RM Billion)",
  "width": 200,
  "height": 380,
  "data": {
    "url": "https://raw.githubusercontent.com/DnzL88/Data-Visualization-2/refs/heads/main/A2/Dataset_files/Trade_by_states.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "y": {
      "field": "State",
      "type": "nominal",
      "sort": "-x",
      "axis": {
        "title": null
      }
    },
    "x": {
      "field": "Export",
      "type": "quantitative",
      "axis": {
        "title": "Export Value (RM Billion)"
      }
    },
    "color": {
      "value": "#185FA5"
    },
    "tooltip": [
      {
        "field": "State",
        "type": "nominal"
      },
      {
        "field": "Export",
        "type": "quantitative",
        "title": "Export (RM Bil)",
        "format": ".1f"
      }
    ]
  }
}